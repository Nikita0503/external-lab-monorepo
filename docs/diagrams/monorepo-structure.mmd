graph LR
    subgraph Apps["apps"]
        FE["frontend-app"]
        MB["mobile-app"]
        BE["backend-app"]
    end

    subgraph Packages["packages"]
        TYPES["types"]
        CONST["constants"]
        API["api"]
        STORE["store"]
        HOOKS["hooks"]
    end

    FE --> HOOKS
    FE --> STORE
    MB --> HOOKS
    MB --> STORE
    HOOKS --> STORE
    HOOKS --> API
    STORE --> API
    STORE --> CONST
    API --> TYPES
    STORE --> TYPES

    FE -.->|HTTP| BE
    MB -.->|HTTP| BE

    style FE fill:#3D78F0,color:#fff
    style MB fill:#6871EE,color:#fff
    style BE fill:#262B4F,color:#fff
